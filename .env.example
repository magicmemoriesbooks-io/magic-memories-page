# ============================================================
# Magic Memories Books - Variables de Entorno
# ============================================================
# Copia este archivo como .env y rellena con tus datos reales:
#   cp .env.example .env
#   nano .env
# ============================================================

# --- BASE DE DATOS ---
# Para MySQL (producción): mysql+pymysql://usuario:contraseña@localhost/magicmemories
# Si no se configura, usa SQLite local (solo desarrollo)
DATABASE_URL=mysql+pymysql://usuario:contraseña@localhost/magicmemories

# --- CLAVE DE SESIÓN ---
# Cadena aleatoria larga para seguridad de sesiones Flask
# Genera una con: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=cambia-esto-por-una-clave-aleatoria-larga

# --- DOMINIO DEL SITIO ---
# Tu dominio de producción (sin https://, sin / al final)
SITE_DOMAIN=www.magicmemoriesbooks.com

# --- OPENAI (Generación de texto de cuentos) ---
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# --- REPLICATE (Generación de imágenes FLUX) ---
# Obtener en: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_...

# --- PADDLE (Pagos) ---
# Obtener en: https://vendors.paddle.com/
# IMPORTANTE: Cambia PADDLE_ENVIRONMENT a "production" cuando estés listo para cobrar de verdad
PADDLE_ENVIRONMENT=sandbox
PADDLE_API_KEY=pdl_...
PADDLE_SELLER_ID=tu_seller_id
PADDLE_CLIENT_TOKEN=ctok_...
PADDLE_WEBHOOK_SECRET=pdl_ntfset_...

# IDs de productos y precios de Paddle (se obtienen al crear productos en el panel de Paddle)
# Quick Stories Digital ($20)
PADDLE_QS_DIGITAL_PRODUCT_ID=pro_...
PADDLE_QS_DIGITAL_PRICE_ID=pri_...

# Quick Stories Impreso (precio base $20 + envío dinámico Lulu)
PADDLE_QS_PRINT_PRODUCT_ID=pro_...

# Libros Personalizados Impreso (precio base $30 + envío dinámico Lulu)
PADDLE_PERSONALIZED_PRODUCT_ID=pro_...

# eBook Interactivo ($7)
PADDLE_EBOOK_PRODUCT_ID=pro_...
PADDLE_EBOOK_PRICE_ID=pri_...

# --- LULU (Impresión de libros) ---
# Obtener en: https://developers.lulu.com/
# IMPORTANTE: Cambia LULU_USE_SANDBOX a "false" cuando estés listo para imprimir de verdad
LULU_USE_SANDBOX=true

# Credenciales de SANDBOX (para pruebas)
LULU_SANDBOX_CLIENT_KEY=tu_sandbox_key
LULU_SANDBOX_CLIENT_SECRET=tu_sandbox_secret

# Credenciales de PRODUCCIÓN (para impresión real)
LULU_CLIENT_KEY=tu_production_key
LULU_CLIENT_SECRET=tu_production_secret

# --- EMAIL / SMTP ---
# Para Gmail: activa "Contraseñas de aplicación" en tu cuenta Google
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=info@magicmemoriesbooks.com
SMTP_EMAIL=info@magicmemoriesbooks.com
SMTP_PASSWORD=tu_contraseña_de_aplicacion
FROM_NAME=Magic Memories Books

# --- VPS / SFTP (Subida de visores eBook) ---
# Si la app corre DIRECTAMENTE en el VPS (producción), usa modo local:
# LOCAL_VISOR_MODE=true → copia archivos sin SFTP (requiere que la app tenga acceso de escritura a VPS_VISOR_PATH)
LOCAL_VISOR_MODE=true
VPS_VISOR_PATH=/var/www/magicmemoriesbooks.com/visor/biblioteca

# Si la app corre en Replit y sube al VPS por SSH/SFTP, configura esto:
VPS_HOST=tu_ip_o_dominio_vps
VPS_USER=tu_usuario_ssh
VPS_PASSWORD=tu_contraseña_ssh
VPS_PORT=22

# --- WORKERS (Procesamiento en segundo plano) ---
# Número de trabajadores paralelos (recomendado: número de CPUs - 1)
TASK_WORKERS=3
IMAGE_PARALLEL_WORKERS=3

# --- ADMIN ---
# Contraseña para acceder al panel de administración (/admin)
ADMIN_PASSWORD=cambia-esto-por-contraseña-segura

# --- eBOOK ---
# Días antes de que expire el acceso a un eBook (por defecto 180 = 6 meses)
EBOOK_EXPIRY_DAYS=180
